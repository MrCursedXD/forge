# Copy this file to `.env` for local development with `netlify dev`.
# Never commit your real .env file — .gitignore already excludes it.
#
# In production (once deployed to Netlify), set this same variable in:
# Netlify dashboard → Site settings → Environment variables → GROQ_API_KEY
# then trigger a redeploy. Netlify functions read it from there, not from this file.

GROQ_API_KEY=your_groq_api_key_here
